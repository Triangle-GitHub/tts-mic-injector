{
    "aliyun": {
        "api_key": "sk-",
        "model": "qwen3-tts-flash-realtime",
        "voice": "Ethan"
    },

    "paths": {
        "espeak": "espeak-ng.exe",
        "piper": "piper.exe",
        "piper_models": "piper_models",
        "ffmpeg": "ffmpeg"
